{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "EnterPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/pre-plan.sh\"",
            "statusMessage": "Loading Techlead workflow..."
          }
        ],
        "description": "Inject techlead-workflow skill before planning"
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/session-start.sh\"",
            "statusMessage": "Loading Techlead workflow..."
          }
        ],
        "description": "Inject techlead-workflow (persona + routing) as session context"
      }
    ]
  }
}
